# Midscene AI model config (required)
# Supports OpenAI-compatible models like GPT-4o, Qwen-VL, Doubao, etc.

# Model name (required)
MIDSCENE_MODEL_NAME=doubao-seed-2.0-pro

# API Key (required) - 请替换为你的实际 API Key
MIDSCENE_MODEL_API_KEY=ark-8f803a84-c1f3-4a1a-b10e-0e6f2835f2bf-7e16b

# API Base URL (optional, needed for non-OpenAI providers)
MIDSCENE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

MIDSCENE_MODEL_FAMILY=doubao-seed
# Proxy (optional)
# MIDSCENE_MODEL_HTTP_PROXY=http://127.0.0.1:7890
# MIDSCENE_MODEL_SOCKS_PROXY=socks5://127.0.0.1:7890
