# Midscene AI model config (required)
# Supports OpenAI-compatible models like GPT-4o, Qwen-VL, Doubao, etc.

# Model name (required)
MIDSCENE_MODEL_NAME=gpt-4o

# API Key (required)
MIDSCENE_MODEL_API_KEY=sk-xxxxx

# API Base URL (optional, needed for non-OpenAI providers)
# MIDSCENE_MODEL_BASE_URL=https://api.openai.com/v1

# Proxy (optional)
# MIDSCENE_MODEL_HTTP_PROXY=http://127.0.0.1:7890
# MIDSCENE_MODEL_SOCKS_PROXY=socks5://127.0.0.1:7890